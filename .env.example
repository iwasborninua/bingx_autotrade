# Telegram API credentials.
# Get these values from https://my.telegram.org/apps.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=
TELEGRAM_SESSION_NAME=bingx_autotrade_telethon

# Telegram source group and forum topic IDs.
GROUP_ID=
TOPIC_BOT_1=
TOPIC_BOT_2=
TOPIC_BOT_1_TRADE=true
TOPIC_BOT_2_TRADE=false


# Signal filters.
# The bot ignores signals with a lower score.
MIN_SIGNAL_SCORE=2

# =========================
# SIGNAL FILTERS
# =========================
ENABLE_SIGNAL_FILTERS=true

# LONG, SHORT, BOTH
ALLOWED_SIGNAL_SIDE=LONG

# RR TP3 filter
ENABLE_RR_TP3_FILTER=true
RR_TP3_MIN=0.8
RR_TP3_MAX=1.5

# Session filter
ENABLE_SESSION_FILTER=true
ALLOWED_SESSIONS=Asia

# BTC 1h change filter
ENABLE_BTC_CHANGE_1H_FILTER=true
BTC_CHANGE_1H_MIN=-1
BTC_CHANGE_1H_MAX=0

# How to combine session and BTC filters: OR or AND.
SESSION_BTC_FILTER_MODE=OR

# If true, RR filter is always required.
RR_FILTER_IS_REQUIRED=true

# =========================
# EXIT STRATEGY
# =========================
TP1_CLOSE_PERCENT=0
TP2_CLOSE_PERCENT=0
TP3_CLOSE_PERCENT=100

# none
# move_sl_to_be_after_tp1
# move_sl_to_be_after_tp1_and_to_tp1_after_tp2
STOP_MOVE_MODE=move_sl_to_be_after_tp1

# If true, touching TP1 moves SL to breakeven even if TP1_CLOSE_PERCENT=0.
MOVE_SL_TO_BE_ON_TP1_TOUCH=true


# MySQL connection.
# Create this database before running migrations.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=bingx_autotrade
DB_USERNAME=bingx_autotrade
DB_PASSWORD=


# BingX mode.
# Use "live" for real trading or "demo" for BingX demo/testnet keys.
BINGX_MODE=live

# Optional BingX API base URL override.
# Leave empty to auto-select:
# - live: https://open-api.bingx.com
# - demo: https://open-api-vst.bingx.com
BINGX_BASE_URL=

# BingX API credentials.
BINGX_API=
BINGX_SECRET=
BINGX_EXCLUDED_CONTRACT_PREFIXES=NCSK,NCFX,NCCO
BINGX_EXCLUDED_DISPLAY_ASSETS=TSLA,MSFT,GOOGL,AMZN,AAPL,NVDA,META,EURUSD,EURJPY,USDJPY,EURCAD,GBPJPY,GBPUSD,AUDUSD,EURGBP,EURCHF,AUDJPY,GBPCHF,GBPSGD,EURSGD,CADJPY,NZDJPY,GOLD,SILVER,XAU,XAG,XAUAUD,XAUEUR,XAUJPY

# BingX trade limits and sizing.
BINGX_LIMIT_OPENED_POSITIONS=1
BINGX_MARGIN=10
BINGX_LEVERAGE=10

# Futures margin mode: ISOLATED, CROSS, or SEPARATE_ISOLATED.
# CROSS is sent to BingX API as CROSSED.
BINGX_MARGIN_TYPE=ISOLATED

# How often the bot syncs open positions and PnL.
BINGX_POSITION_CHECK_INTERVAL_SECONDS=60

# Print DB-based trade statistics after each position sync.
BINGX_LOG_STATS_EACH_CHECK=true

# =========================
# Signal source mode
# =========================

# telegram | own | both
SIGNAL_SOURCE_MODE=telegram
AUTO_TRADE_ENABLED=false
OWN_AUTO_TRADE_ENABLED=false
PAPER_TRADING=true
KILL_SWITCH=false
KILL_SWITCH_CLOSE_POSITIONS=false

# =========================
# Own strategy
# =========================

OWN_STRATEGY_ENABLED=false
OWN_STRATEGY_NAME=RS_PULLBACK_V1
OWN_SCAN_TIMEFRAME=15m
OWN_SCAN_INTERVAL_SECONDS=30
OWN_ORDER_FILL_CHECK_INTERVAL_SECONDS=5
OWN_USE_CLOSED_CANDLES_ONLY=true
OWN_HISTORY_DAYS=7
OWN_MAX_SYMBOLS=0
OWN_SYMBOL_WHITELIST=
OWN_SYMBOL_BLACKLIST=PAXGUSDT,XAUTUSDT,GOLDUSDT,SILVERUSDT,OILUSDT

# =========================
# Market data sources
# =========================

OWN_CANDLES_SOURCE=bingx
OWN_OI_SOURCE=coinalyze
OWN_FUNDING_SOURCE=coinalyze
BINGX_MARKET_BASE_URL=https://open-api.bingx.com
BINGX_MARKET_MAX_REQUESTS_PER_MINUTE=450
COINALYZE_API_KEY=
# Backward-compatible alias accepted by the app.
COINALYZE_API=
COINALYZE_BASE_URL=https://api.coinalyze.net/v1
COINALYZE_MAX_REQUESTS_PER_MINUTE=35
COINALYZE_REQUEST_RESERVE=7
COINALYZE_OI_BATCH_SIZE=7

# =========================
# RS Pullback v1 filters
# =========================

RS_PULLBACK_ENABLED=true
RS_PULLBACK_MIN_RELATIVE_STRENGTH_1H=2.0
RS_PULLBACK_MIN_PRICE_CHANGE_1H=1.5
RS_PULLBACK_MIN_VOLUME_RATIO_15M=1.8
RS_PULLBACK_MIN_OI_CHANGE_15M=1.0
RS_PULLBACK_MIN_BTC_CHANGE_1H=-0.5
RS_PULLBACK_ATR_PERIOD=14
RS_PULLBACK_ENTRY_PULLBACK_ATR_MULT=1.0
RS_PULLBACK_STOP_ATR_MULT=1.5
RS_PULLBACK_MAX_RISK_DISTANCE_PCT=8.0
RS_PULLBACK_TP1_R=0.75
RS_PULLBACK_TP2_R=1.5
RS_PULLBACK_TP3_R=2.5
RS_PULLBACK_TTL_HOURS=6
RS_PULLBACK_INTRABAR_MODE=one_minute_resolved
RS_PULLBACK_CLOSE_IF_MFE_BELOW_R_AFTER_HOURS=2
RS_PULLBACK_CLOSE_IF_MFE_BELOW_R_VALUE=1.0
RS_PULLBACK_MOVE_SL_AFTER_TP1_ENABLED=true
RS_PULLBACK_MOVE_SL_AFTER_TP1_TO_R=0.5
RS_PULLBACK_CLOSE_IF_SL_PLACE_FAILED=true
RS_PULLBACK_MAX_OI_STALENESS_MINUTES=30

# =========================
# Own strategy capital
# =========================

OWN_MAX_OPEN_POSITIONS=2
OWN_USE_GLOBAL_OPEN_POSITION_LIMIT=true
OWN_BLOCK_DUPLICATE_SYMBOL=true
OWN_BLOCK_SYMBOL_USED_BY_TELEGRAM=true
TELEGRAM_BLOCK_SYMBOL_USED_BY_OWN=true
